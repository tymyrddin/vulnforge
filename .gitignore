# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
