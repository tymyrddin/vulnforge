.ruff_cache/

# Vulnforge runtime should live under $XDG_DATA_HOME/vulnforge/, not in the
# checkout. This entry is defensive: catches stray .vulnforge/ directories
# that earlier versions wrote here, or that a user creates by mistake.
# Bootstrap output (sandbox.lock) is per-machine state.
.vulnforge/
bootstrap/sandbox.lock

# Secrets
.env
.env.*
!.env.example
*.key
*.pem
