# Vulnforge runtime should live under $XDG_DATA_HOME/vulnforge/, not in the
# checkout. These entries are defensive: they catch stray directories that
# appear if someone passes --workspace . from inside the repo, or that earlier
# versions wrote here. Bootstrap output (sandbox.lock) is per-machine state.
.vulnforge/
bootstrap/sandbox.lock
runs/

# Secrets
.env
.env.*
!.env.example
*.key
*.pem
